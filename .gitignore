# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ── Security: Never commit these ──────────────────────────
# Trained model files (large + sensitive)
*.pkl
*.joblib
*.h5
models/
admin/models/

# Raw data fetched from APIs (can contain personal/geo info)
data/raw/
admin/data/raw/
*.csv

# Admin pipeline output logs
admin/logs/
admin/output/

# API keys / secrets
.env.local
.env.production
secrets.json
api_keys.json

# Python cache
__pycache__/
*.pyc
*.pyo
.pytest_cache/
admin/__pycache__/

# Jupyter checkpoints
.ipynb_checkpoints/
